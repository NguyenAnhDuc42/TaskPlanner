{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://taskplanner-production-9377.up.railway.app/api/:path*" },
    { "source": "/hubs/:path*", "destination": "https://taskplanner-production-9377.up.railway.app/hubs/:path*" }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)\\.(.+)", "dest": "/$1.$2" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
