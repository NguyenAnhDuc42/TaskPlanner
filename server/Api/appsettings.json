{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Mvc": "Information",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "AppSettings": {
    "FrontendUrl": "https://orpus.app",
    "BackendUrl": "https://api.orpus.app"
  },
  "JwtSettings": {
    "Expiration": 15,
    "RefreshExpiration": 30
  },
  "CookieSettings": {
    "UseSecure": true,
    "AccessTokenCookieName": "acct",
    "RefreshTokenCookieName": "rft",
    "AccessTokenExpireCookieName": "atexp",
    "SessionPresentCookieName": "is_logged_in",
    "Domain": ".orpus.app",
    "SameSite": "Lax"
  },
  "PerformanceSettings": {
    "DbContextPoolSize": 16,
    "DatabaseMaxRetryCount": 3,
    "DatabaseMaxRetryDelaySeconds": 2
  },
  "RateLimitSettings": {
    "MaxRequestsPerMinute": 60
  },
  "CacheSettings": {
    "MemoryCacheLimitMB": 20
  },
  "EmailSettings": {
    "Port": 587,
    "FromName": "TaskPlanner"
  },
  "AllowedHosts": "*"
}
